{
  "name": "agentic-island",
  "version": "0.6.2",
  "description": "常驻 Windows 屏幕顶部的 AI 编码 Agent 状态监控、审批与协作面板",
  "main": "./out/main/index.js",
  "author": "Agentic-Island",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "probe": "node --experimental-strip-types scripts/probe.mjs",
    "demo:plan": "node scripts/demo-plan.mjs",
    "docs:capture": "node scripts/capture-readme.mjs",
    "package": "electron-vite build && electron-builder --win nsis --publish never",
    "verify:package": "node scripts/verify-package.mjs"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^10.0.0",
    "ffmpeg-static": "^5.2.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "onnxruntime-web": "^1.27.0",
    "pdf-parse": "^2.4.5"
  },
  "build": {
    "appId": "com.agentic.island",
    "productName": "Agentic-Island",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/ffmpeg-static/**"
    ],
    "extraResources": [
      {
        "from": "src/hooks-bin",
        "to": "hooks-bin"
      },
      {
        "from": "build/icon-256.png",
        "to": "icon-256.png"
      },
      {
        "from": "resources/models",
        "to": "models"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Agentic-Island-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Agentic-Island"
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.6",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "overrides": {
    "esbuild": "0.25.12",
    "tar": "7.5.19"
  }
}
